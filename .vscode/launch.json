{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Node Server",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "cwd": "${workspaceFolder}/node-server",
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "restart": true
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Current TypeScript File",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "runtimeArgs": [
                "-r",
                "ts-node/register"
            ],
            "args": [
                "${file}"
            ],
            "cwd": "${workspaceFolder}/node-server",
            "console": "integratedTerminal"
        }
    ]
}